# Firebase Functions environment variables
# Copy these values into functions/.env for local emulation
# and into Firebase runtime config/secrets for production.

JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=7d

# Option A: single connection string
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/startiqo?sslmode=require

# Option B: individual values
PGHOST=localhost
PGPORT=5432
PGDATABASE=startiqo
PGUSER=postgres
PGPASSWORD=replace_with_db_password
DATABASE_SSL=false
